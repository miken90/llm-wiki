sources/*
!sources/.gitkeep
!sources/assets/
sources/assets/*
!sources/assets/.gitkeep
!sources/articles/
sources/articles/*
!sources/articles/.gitkeep
wiki/entities/*
!wiki/entities/.gitkeep
wiki/concepts/*
!wiki/concepts/.gitkeep
wiki/summaries/*
!wiki/summaries/.gitkeep
wiki/syntheses/*
!wiki/syntheses/.gitkeep
wiki/decisions/*
!wiki/decisions/.gitkeep
outputs/*
!outputs/.gitkeep

# Plans and internal tooling
plans/
.claude/
.team/

# Discovery state (runtime)
.discoveries/*.json

# User config (contains local topics/feeds)
config.yaml
